{
  "name": "assist-dicom-lite",
  "version": "1.0.0",
  "description": "Lightweight DICOM listener and forwarder",
  "main": "index.js",
  "bin": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "build": "pkg . --targets node12-win-x64 --output dist/DICOM-Router-Lite.exe",
    "build:win7": "pkg . --targets node12-win-x64 --output dist/DICOM-Router-Lite-Win7.exe",
    "build:full": "node build.js"
  },
  "engines": {
    "node": ">=12.22.0 <13.0.0",
    "npm": ">=6.14.0"
  },
  "dependencies": {
    "axios": "^0.27.2",
    "dicom-parser": "^1.8.13",
    "dotenv": "^10.0.0",
    "form-data": "^4.0.0",
    "fs-extra": "^10.1.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.20",
    "pkg": "^5.8.0"
  },
  "pkg": {
    "scripts": [
      "config/**/*.js",
      "services/**/*.js",
      "database/**/*.js"
    ],
    "assets": [
      "storage/**/*"
    ],
    "targets": [
      "node12-win-x64"
    ],
    "outputPath": "dist"
  },
  "license": "MIT"
}
