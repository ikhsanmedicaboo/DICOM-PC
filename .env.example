# API Configuration
API_URL=https://api-dicom-router.assist.id/api/receive
API_KEY=your-api-key-here
API_BEARER_TOKEN=
API_TIMEOUT=30000
HOSPITAL_ID=your-hospital-id-here

# Server Configuration
WEB_PORT=3000
NODE_ENV=production
HOST=0.0.0.0

# Storage Configuration
MAX_STORAGE_GB=10
RETENTION_DAYS=30
DB_PATH=./storage/logs.db

# Logging
LOG_LEVEL=info
LOG_FILE=./storage/logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=7

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY=5000

# Security
ENABLE_AUTH=false
DASHBOARD_PASSWORD=

# Performance
CONCURRENT_UPLOADS=3
CLEANUP_INTERVAL=3600000
